{
  "name": "claude-notomate-action",
  "version": "0.1.0",
  "private": true,
  "description": "GitHub Action that runs the Claude Agent SDK against a notomate comment tagging @claude, wrapping the notomate API as an in-process MCP server.",
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/test.mjs"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@anthropic-ai/claude-agent-sdk": "^0.1.77",
    "@hocuspocus/provider": "^4.4.0",
    "jsonwebtoken": "^9.0.0",
    "tsx": "^4.19.2",
    "ws": "^8.18.0",
    "yjs": "^13.6.29",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "typescript": "^5.7.2"
  }
}
