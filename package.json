{
  "name": "claude-notomate-action",
  "version": "0.1.0",
  "private": true,
  "description": "GitHub Action that runs the Claude Agent SDK against a notomate comment tagging @claude, wrapping the notomate API as an in-process MCP server.",
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@anthropic-ai/claude-agent-sdk": "^0.1.77",
    "tsx": "^4.19.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
